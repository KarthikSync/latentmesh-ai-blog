---
import { SITE_AUTHOR, GITHUB_URL } from "../consts";

const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <span>&copy; {year} {SITE_AUTHOR}</span>
    <div class="footer-links">
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="/blog">Blog</a>
      <a href="/about">About</a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid #eee;
    padding: 2rem 1.5rem;
    margin-top: 2rem;
  }

  .footer-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  footer span {
    font-family: sans-serif;
    font-size: 0.9rem;
    color: #888;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    font-family: sans-serif;
    font-size: 0.9rem;
    color: #888;
    text-decoration: none;
  }

  .footer-links a:hover {
    color: #111;
  }
</style>