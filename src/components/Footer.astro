---
import { SITE_AUTHOR, GITHUB_URL, LINKEDIN_URL } from "../consts";

const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-copy">&copy; {year} {SITE_AUTHOR}</span>
      <span class="footer-tagline">Writing on AI systems, evals, safety, and governance.</span>
    </div>
    <div class="footer-links">
      <a href="/blog">Essays</a>
      <a href="/about">About</a>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer">LinkedIn</a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid #eee;
    padding: 2rem 1rem;
    margin-top: 2rem;
  }

  .footer-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-copy {
    font-family: sans-serif;
    font-size: 0.85rem;
    color: #888;
  }

  .footer-tagline {
    font-family: sans-serif;
    font-size: 0.8rem;
    color: #aaa;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    font-family: sans-serif;
    font-size: 0.85rem;
    color: #888;
    text-decoration: none;
  }

  .footer-links a:hover {
    color: #111;
  }
</style>
