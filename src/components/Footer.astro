---
import { GITHUB_URL, LINKEDIN_URL } from "../consts";
---

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-name">LatentMesh</span>
      <span class="footer-tagline">Writing on AI agents, evaluation, compliance, and governance.</span>
    </div>
    <div class="footer-links">
      <a href="/reading-list">Reading List</a>
      <a href="/about">About</a>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" onclick="gtag('event','outbound_click',{destination:'github',location:'footer'})">GitHub</a>
      <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" onclick="gtag('event','outbound_click',{destination:'linkedin',location:'footer'})">LinkedIn</a>
    </div>
  </div>
  <div class="footer-disclaimer">
    <p>The views expressed on this website are my own and do not represent the views of my employer. Any opinions or guidance shared here are informational, not legal advice.</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    padding: 2.5rem 2rem;
    margin-top: 2rem;
  }

  .footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .footer-name {
    font-family: sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .footer-tagline {
    font-family: sans-serif;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    font-family: sans-serif;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--color-text-primary);
  }

  .footer-disclaimer {
    max-width: 1120px;
    margin: 1.25rem auto 0;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border-light);
  }

  .footer-disclaimer p {
    font-family: sans-serif;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
