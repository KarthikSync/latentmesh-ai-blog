---
import { GITHUB_URL, LINKEDIN_URL } from "../consts";
---

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-name">LatentMesh</span>
      <span class="footer-tagline">Writing on AI agents, evaluation, compliance, and governance.</span>
    </div>
    <div class="footer-links">
      <a href="/blog">Essays</a>
      <a href="/about">About</a>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer">LinkedIn</a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid #e5e7eb;
    padding: 2.5rem 1.25rem;
    margin-top: 2rem;
  }

  .footer-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .footer-name {
    font-family: sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: #1e293b;
  }

  .footer-tagline {
    font-family: sans-serif;
    font-size: 0.8rem;
    color: #94a3b8;
    line-height: 1.5;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    font-family: sans-serif;
    font-size: 0.85rem;
    color: #64748b;
    text-decoration: none;
  }

  .footer-links a:hover {
    color: #1e293b;
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
