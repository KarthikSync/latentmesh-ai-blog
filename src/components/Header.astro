---
import { SITE_TITLE } from "../consts";
---

<header>
  <nav>
    <a href="/" class="site-title">{SITE_TITLE}</a>
    <div class="nav-links">
      <a href="/blog">Blog</a>
      <a href="/about">About</a>
    </div>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid #eee;
    padding: 1rem 1.5rem;
  }

  nav {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-title {
    font-family: sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: #111;
    text-decoration: none;
  }

  .site-title:hover {
    color: #444;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    font-family: sans-serif;
    font-size: 0.95rem;
    color: #555;
    text-decoration: none;
  }

  .nav-links a:hover {
    color: #111;
  }
</style>