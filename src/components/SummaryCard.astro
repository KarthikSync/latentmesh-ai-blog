---
interface Props {
	summary: string;
	problem: string;
	coreIdea: string;
	takeaway: string;
}

const { summary, problem, coreIdea, takeaway } = Astro.props;
---

<aside class="summary-card">
	<div class="summary-header">
		<span class="summary-label">In 30 seconds</span>
		<span class="summary-badge">Author-reviewed summary</span>
	</div>
	<h2 class="summary-title">Why this essay matters</h2>
	<p class="summary-text">{summary}</p>
	<div class="summary-tags">
		<div class="summary-tag">
			<span class="tag-label">Problem</span>
			<span class="tag-value">{problem}</span>
		</div>
		<div class="summary-tag">
			<span class="tag-label">Core idea</span>
			<span class="tag-value">{coreIdea}</span>
		</div>
		<div class="summary-tag">
			<span class="tag-label">Takeaway</span>
			<span class="tag-value">{takeaway}</span>
		</div>
	</div>
</aside>

<style>
	.summary-card {
		border: 1px solid var(--color-border);
		border-radius: 10px;
		padding: 1.75rem;
		margin: 2rem 0 2.5rem;
		background: var(--color-bg);
	}

	.summary-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 0.75rem;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.summary-label {
		font-family: sans-serif;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--color-link);
	}

	.summary-badge {
		font-family: sans-serif;
		font-size: 0.65rem;
		font-weight: 500;
		color: var(--color-text-muted);
		border: 1px solid var(--color-border);
		border-radius: 4px;
		padding: 0.2rem 0.5rem;
	}

	.summary-title {
		font-family: sans-serif;
		font-size: 1.1rem;
		font-weight: 700;
		margin: 0 0 0.75rem;
		color: var(--color-text-primary);
	}

	.summary-text {
		font-size: 0.9rem;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin: 0 0 1.25rem;
	}

	.summary-tags {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.75rem;
		border-top: 1px solid var(--color-border-light);
		padding-top: 1rem;
	}

	.summary-tag {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.tag-label {
		font-family: sans-serif;
		font-size: 0.65rem;
		font-weight: 500;
		color: var(--color-text-muted);
		text-transform: capitalize;
	}

	.tag-value {
		font-family: sans-serif;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--color-text-primary);
		line-height: 1.35;
	}

	@media (max-width: 480px) {
		.summary-card {
			padding: 1.25rem;
			margin: 1.5rem 0 2rem;
		}

		.summary-tags {
			grid-template-columns: 1fr;
			gap: 0.6rem;
		}
	}
</style>
