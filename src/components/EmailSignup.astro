---
interface Props {
  variant: "card" | "section";
  heading?: string;
  body: string;
  showPrivacy?: boolean;
}

const { variant, heading, body, showPrivacy = true } = Astro.props;
const isSection = variant === "section";
---

<div class={`email-signup email-signup--${variant}`}>
  <div class="email-signup__inner">
    {heading && <p class="email-signup__heading">{heading}</p>}
    <p class="email-signup__body">{body}</p>
    <form class="email-signup__form" data-email-form>
      <label for="email-input" class="sr-only">Email address</label>
      <input
        type="email"
        id="email-input"
        name="email"
        placeholder="your@email.com"
        required
        class="email-signup__input"
      />
      <button type="submit" class="email-signup__button">
        Subscribe
      </button>
    </form>
    <div class="email-signup__status" role="status" aria-live="polite"></div>
    {showPrivacy && <p class="email-signup__privacy">No spam. Unsubscribe anytime.</p>}
  </div>
</div>

<script>
  document.querySelectorAll('[data-email-form]').forEach((form) => {
    if (form.getAttribute('data-wired')) return;
    form.setAttribute('data-wired', 'true');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const input = f.querySelector('input') as HTMLInputElement;
      const button = f.querySelector('button') as HTMLButtonElement;
      const status = f.parentElement?.querySelector('.email-signup__status') as HTMLElement;
      const email = input.value.trim();
      if (!email) return;

      // Submitting state
      button.textContent = 'Sending...';
      button.disabled = true;
      input.disabled = true;
      status.textContent = '';
      status.className = 'email-signup__status';

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email_address: email }),
        });

        const data = await res.json();

        if (res.status === 201 || data.status === 'subscribed') {
          f.style.display = 'none';
          status.textContent = "You're in. First note arrives next week.";
          status.className = 'email-signup__status email-signup__status--success';
        } else if (data.status === 'already_subscribed') {
          f.style.display = 'none';
          status.textContent = "You're already subscribed.";
          status.className = 'email-signup__status email-signup__status--success';
        } else {
          throw new Error(data.error || 'Subscription failed');
        }

        const privacy = f.parentElement?.querySelector('.email-signup__privacy') as HTMLElement;
        if (privacy) privacy.style.display = 'none';

        if (typeof (window as any).gtag === 'function') {
          (window as any).gtag('event', 'email_subscribe', {
            location: f.closest('.email-signup')?.classList.contains('email-signup--section') ? 'homepage' : 'article',
          });
        }
      } catch {
        // Error state
        button.textContent = 'Subscribe';
        button.disabled = false;
        input.disabled = false;
        input.classList.add('email-signup__input--error');
        status.textContent = 'Something went wrong. Try again?';
        status.className = 'email-signup__status email-signup__status--error';
      }
    });
  });
</script>

<style>
  /* ── Shared ── */
  .email-signup__inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .email-signup__heading {
    font-family: sans-serif;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
  }

  .email-signup__body {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .email-signup__form {
    display: flex;
    gap: 0.5rem;
    max-width: 480px;
  }

  .email-signup__input {
    flex: 1;
    height: 48px;
    padding: 0 0.75rem;
    border: 1.5px solid var(--color-border);
    border-radius: 6px;
    font-family: sans-serif;
    font-size: 0.88rem;
    color: var(--color-text-primary);
    background: #ffffff;
    transition: border-color 150ms;
  }

  :global([data-theme="dark"]) .email-signup__input {
    background: var(--color-bg);
  }

  .email-signup__input::placeholder {
    color: var(--color-text-muted);
  }

  .email-signup__input:focus {
    outline: none;
    border-color: var(--color-text-primary);
  }

  .email-signup__input--error {
    border-color: #c0392b;
  }

  .email-signup__button {
    height: 48px;
    padding: 0 1.25rem;
    background: var(--color-text-primary);
    color: var(--color-bg);
    border: none;
    border-radius: 6px;
    font-family: sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 150ms;
    white-space: nowrap;
  }

  .email-signup__button:hover { opacity: 0.85; }
  .email-signup__button:disabled { opacity: 0.6; cursor: not-allowed; }

  .email-signup__privacy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0.75rem 0 0;
  }

  .email-signup__status {
    font-size: 0.88rem;
    margin-top: 0.75rem;
  }

  .email-signup__status--success {
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .email-signup__status--error {
    font-size: 0.8rem;
    color: #c0392b;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Card variant (end-of-article) ── */
  .email-signup--card {
    margin-top: 3rem;
    padding: 2rem 2.5rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .email-signup--card .email-signup__heading {
    font-size: 1.25rem;
  }

  .email-signup--card .email-signup__body {
    font-size: 1rem;
  }

  /* ── Section variant (homepage) ── */
  .email-signup--section {
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border-light);
    border-bottom: 1px solid var(--color-border-light);
    padding: 4rem 2rem;
    text-align: center;
  }

  .email-signup--section .email-signup__heading {
    font-size: 1.5rem;
  }

  .email-signup--section .email-signup__body {
    font-size: 1.05rem;
  }

  .email-signup--section .email-signup__form {
    margin: 0 auto;
  }

  .email-signup--section .email-signup__privacy {
    text-align: center;
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .email-signup--card {
      padding: 1.5rem;
    }

    .email-signup--section {
      padding: 2.5rem 1rem;
      text-align: left;
    }

    .email-signup__form {
      flex-direction: column;
    }

    .email-signup__button {
      width: 100%;
    }
  }
</style>
