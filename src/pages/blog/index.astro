---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Essays | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Essays</h1>
			<div class="essay-list">
				{
					posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="essay-item">
							<div class="essay-content">
								<h2 class="essay-title">{post.data.title}</h2>
								{post.data.description && (
									<p class="essay-summary">{post.data.description}</p>
								)}
							</div>
							<span class="essay-date">
								<FormattedDate date={post.data.pubDate} />
							</span>
						</a>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 760px;
		margin: 0 auto;
		padding: 2.5rem 1.25rem 3.5rem;
	}

	h1 {
		font-size: clamp(1.5rem, 4vw, 2rem);
		font-weight: 800;
		color: #0f172a;
		margin: 0 0 2rem;
		font-family: sans-serif;
		letter-spacing: -0.01em;
	}

	.essay-list {
		display: flex;
		flex-direction: column;
	}

	.essay-item {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1.5rem;
		padding: 1.25rem 0;
		border-bottom: 1px solid #f1f5f9;
		text-decoration: none;
		color: inherit;
	}

	.essay-item:first-child {
		padding-top: 0;
	}

	.essay-item:last-child {
		border-bottom: none;
	}

	.essay-item:hover .essay-title {
		color: #1e3a8a;
	}

	.essay-content {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		min-width: 0;
	}

	.essay-title {
		font-size: 1.15rem;
		font-weight: 600;
		color: #1e293b;
		font-family: sans-serif;
		line-height: 1.35;
		margin: 0;
	}

	.essay-summary {
		font-size: 0.9rem;
		color: #64748b;
		line-height: 1.5;
		margin: 0;
	}

	.essay-date {
		font-size: 0.8rem;
		color: #94a3b8;
		font-family: sans-serif;
		flex-shrink: 0;
		white-space: nowrap;
	}

	@media (max-width: 480px) {
		main {
			padding: 2rem 1rem 3rem;
		}

		.essay-item {
			flex-direction: column;
			gap: 0.25rem;
		}
	}
</style>
