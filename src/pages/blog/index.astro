---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const startHereEssays = [
	{
		slug: "agent-failures-are-distributed-systems-failures",
		title: "Agent Failures Are Distributed Systems Failures",
		summary: "Why agent failures are usually system failures, not just model failures.",
	},
	{
		slug: "the-eval-gap",
		title: "The Eval Gap",
		summary: "Why staging success does not predict production reliability.",
	},
	{
		slug: "controls-are-not-guardrails",
		title: "Controls Are Not Guardrails",
		summary: "Why runtime safety layers are not enough without evidence, ownership, and testing.",
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="AI Compliance and Agent Evaluation Essays | LatentMesh" description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Essays</h1>
			<p class="page-intro">Essays on AI agents, evaluation, safety, privacy, compliance, and governance through the lens of distributed systems and production engineering.</p>

			<!-- Series label -->
			<div class="series-block">
				<p class="series-label">Series: Reliable Agent Systems</p>
				<p class="series-desc">A connected set of essays on failure, evaluation, controls, and proof.</p>
			</div>

			<!-- Start here -->
			<section class="start-here">
				<h2>Start here</h2>
				<p class="section-intro">New to LatentMesh? Start with the core essays on how agent systems fail, how to evaluate them in the real world, and how governance becomes operational.</p>
				<div class="start-here-grid">
					{startHereEssays.map((essay) => (
						<a href={`/blog/${essay.slug}/`} class="start-here-card">
							<h3>{essay.title}</h3>
							<p>{essay.summary}</p>
						</a>
					))}
				</div>
				<a href="/series" class="read-series">Read the series &rarr;</a>
			</section>

			<!-- All essays -->
			<section class="all-essays">
				<h2>All essays</h2>
				<p class="section-intro">Recent writing on reliable agent systems, evidence, safety, and governance.</p>
				<div class="essay-list">
					{
						posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="essay-item">
								<div class="essay-content">
									<h2 class="essay-title">{post.data.title}</h2>
									{post.data.description && (
										<p class="essay-summary">{post.data.description}</p>
									)}
								</div>
								<span class="essay-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 760px;
		margin: 0 auto;
		padding: 2.5rem 1.25rem 3.5rem;
	}

	h1 {
		font-size: clamp(1.5rem, 4vw, 2rem);
		font-weight: 800;
		color: var(--color-text-primary);
		margin: 0 0 0.75rem;
		font-family: sans-serif;
		letter-spacing: -0.01em;
	}

	.page-intro {
		font-size: 1.05rem;
		line-height: 1.6;
		color: var(--color-text-secondary);
		margin: 0 0 2rem;
	}

	/* ── Series block ── */
	.series-block {
		padding: 1.25rem 1.5rem;
		background: var(--color-bg-secondary);
		border-radius: 8px;
		border-left: 3px solid var(--color-link);
		margin-bottom: 2.5rem;
	}

	.series-label {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--color-link);
		margin: 0 0 0.25rem;
		font-family: sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.series-desc {
		font-size: 0.95rem;
		color: var(--color-text-secondary);
		margin: 0;
		line-height: 1.5;
	}

	/* ── Start here ── */
	.start-here {
		margin-bottom: 2.5rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--color-border);
	}

	.start-here h2 {
		font-size: 1.25rem;
		font-weight: 700;
		margin: 0 0 0.5rem;
		color: var(--color-text-primary);
		font-family: sans-serif;
	}

	.section-intro {
		font-size: 0.95rem;
		line-height: 1.6;
		color: var(--color-text-secondary);
		margin: 0 0 1.25rem;
	}

	.start-here-grid {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.start-here-card {
		padding: 1.25rem 1.5rem;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		display: block;
	}

	.start-here-card:hover {
		border-color: var(--color-card-hover);
	}

	.start-here-card h3 {
		font-size: 1.05rem;
		font-weight: 700;
		margin: 0 0 0.3rem;
		color: var(--color-text-primary);
		font-family: sans-serif;
		line-height: 1.3;
	}

	.start-here-card p {
		font-size: 0.9rem;
		line-height: 1.5;
		color: var(--color-text-secondary);
		margin: 0;
	}

	.read-series {
		display: inline-block;
		margin-top: 1rem;
		font-size: 0.9rem;
		font-family: sans-serif;
		font-weight: 600;
		color: var(--color-link);
		text-decoration: none;
	}

	.read-series:hover {
		color: var(--color-brand);
	}

	/* ── All essays ── */
	.all-essays h2 {
		font-size: 1.25rem;
		font-weight: 700;
		margin: 0 0 0.5rem;
		color: var(--color-text-primary);
		font-family: sans-serif;
	}

	.essay-list {
		display: flex;
		flex-direction: column;
	}

	.essay-item {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1.5rem;
		padding: 1.25rem 0;
		border-bottom: 1px solid var(--color-border-light);
		text-decoration: none;
		color: inherit;
	}

	.essay-item:first-child {
		padding-top: 0;
	}

	.essay-item:last-child {
		border-bottom: none;
	}

	.essay-item:hover .essay-title {
		color: var(--color-brand);
	}

	.essay-content {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		min-width: 0;
	}

	.essay-title {
		font-size: 1.15rem;
		font-weight: 600;
		color: var(--color-text-primary);
		font-family: sans-serif;
		line-height: 1.35;
		margin: 0;
	}

	.essay-summary {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		line-height: 1.5;
		margin: 0;
	}

	.essay-date {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		font-family: sans-serif;
		flex-shrink: 0;
		white-space: nowrap;
	}

	@media (max-width: 480px) {
		main {
			padding: 2rem 1rem 3rem;
		}

		.essay-item {
			flex-direction: column;
			gap: 0.25rem;
		}
	}
</style>
