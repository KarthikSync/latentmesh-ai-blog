<script>
function toggleCluster(btn) {
  const sec = btn.closest('.cluster-section');
  const collapsed = sec.getAttribute('data-collapsed') === 'true';
  sec.setAttribute('data-collapsed', collapsed ? 'false' : 'true');
  btn.setAttribute('aria-expanded', collapsed ? 'true' : 'false');
}

function toggleRow(btn, detailId) {
  const detail = document.getElementById(detailId);
  if (!detail) return;
  const isOpen = detail.classList.contains('open');
  detail.classList.toggle('open');
  btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
}

function resetFilters() {
  ['fRole','fCluster','fOwner','fCadence','fArticle','fEvidence'].forEach(function(id) { document.getElementById(id).value = 'all'; });
  applyFilters();
}

function applyFilters() {
  var role = document.getElementById('fRole').value;
  var cluster = document.getElementById('fCluster').value;
  var owner = document.getElementById('fOwner').value;
  var cadence = document.getElementById('fCadence').value;
  var article = document.getElementById('fArticle').value;
  var evidence = document.getElementById('fEvidence').value;

  var totalVisible = 0, totalRows = 0;

  document.querySelectorAll('.cluster-section').forEach(function(sec) {
    var clusterMatch = cluster === 'all' || sec.dataset.cluster === cluster;
    var sectionVisible = 0;

    sec.querySelectorAll('tr.data-row').forEach(function(row) {
      totalRows++;
      var detail = row.nextElementSibling;
      var roleMatch = role === 'all' || row.dataset.role === role;
      var ownerMatch = owner === 'all' || row.dataset.owner === owner;
      var cadenceMatch = cadence === 'all' || row.dataset.cadence === cadence;
      var articleMatch = article === 'all' || (row.dataset.articles || '').split(',').indexOf(article) !== -1;
      var evidenceMatch = evidence === 'all' || row.dataset.evidence === evidence;

      if (clusterMatch && roleMatch && ownerMatch && cadenceMatch && articleMatch && evidenceMatch) {
        row.classList.remove('hidden-row');
        if (detail && detail.classList.contains('detail-row')) {
          detail.classList.remove('hidden-row');
        }
        sectionVisible++;
        totalVisible++;
      } else {
        row.classList.add('hidden-row');
        if (detail && detail.classList.contains('detail-row')) {
          detail.classList.remove('open');
          detail.classList.add('hidden-row');
        }
      }
    });

    if (!clusterMatch || sectionVisible === 0) { sec.classList.add('hidden-cluster'); }
    else { sec.classList.remove('hidden-cluster'); sec.removeAttribute('data-collapsed'); sec.querySelector('.cluster-toggle').setAttribute('aria-expanded','true'); }
  });

  document.getElementById('countBar').textContent = 'Showing ' + totalVisible + ' of ' + totalRows + ' controls';
}

function updateCounts() {
  document.querySelectorAll('.cluster-section').forEach(function(sec) {
    var c = sec.querySelectorAll('tr.data-row').length;
    sec.querySelector('.cluster-count').textContent = c + ' control' + (c !== 1 ? 's' : '');
  });
}

['fRole','fCluster','fOwner','fCadence','fArticle','fEvidence'].forEach(function(id) {
  document.getElementById(id).addEventListener('change', applyFilters);
});

updateCounts();
applyFilters();
</script>

