---
export const prerender = false;

import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

let postStats: { title: string; slug: string; views: number; referrers: Record<string, number> }[] = [];
let totalViews = 0;

try {
  const kv = (Astro.locals as any).runtime.env.VIEW_COUNTS;
  for (const post of posts) {
    const views = parseInt((await kv.get(post.id)) ?? '0', 10);
    totalViews += views;

    const referrers: Record<string, number> = {};
    const refPrefix = `${post.id}:ref:`;
    const list = await kv.list({ prefix: refPrefix });
    for (const key of list.keys) {
      const source = key.name.replace(refPrefix, '');
      const count = parseInt((await kv.get(key.name)) ?? '0', 10);
      if (count > 0) referrers[source] = count;
    }

    postStats.push({ title: post.data.title, slug: post.id, views, referrers });
  }
} catch (e) {
  // KV not available (local dev)
}

postStats.sort((a, b) => b.views - a.views);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Analytics | ${SITE_TITLE}`} description="Private analytics dashboard." />
  </head>
  <body>
    <Header />
    <main>
      <h1>Analytics</h1>
      <p class="total">Total views: <strong>{totalViews}</strong></p>

      {postStats.length === 0 && <p class="empty">No view data yet.</p>}

      {postStats.map((post) => (
        <div class="post-stats">
          <div class="post-header">
            <a href={`/blog/${post.slug}/`} class="post-title">{post.title}</a>
            <span class="post-views">{post.views} views</span>
          </div>
          {Object.keys(post.referrers).length > 0 && (
            <div class="referrers">
              {Object.entries(post.referrers)
                .sort((a, b) => b[1] - a[1])
                .map(([source, count]) => (
                  <span class="ref-item">
                    <span class="ref-source">{source}</span>
                    <span class="ref-count">{count}</span>
                  </span>
                ))}
            </div>
          )}
        </div>
      ))}
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 3.5rem;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
    font-family: sans-serif;
  }

  .total {
    font-size: 1rem;
    color: var(--color-text-secondary);
    font-family: sans-serif;
    margin: 0 0 2rem;
  }

  .total strong {
    color: var(--color-text-primary);
  }

  .empty {
    color: var(--color-text-muted);
    font-family: sans-serif;
  }

  .post-stats {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .post-stats:last-child {
    border-bottom: none;
  }

  .post-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .post-title {
    font-family: sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .post-title:hover {
    color: var(--color-link);
  }

  .post-views {
    font-family: sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .referrers {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .ref-item {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: sans-serif;
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
    background: var(--color-bg-secondary);
    border-radius: 4px;
  }

  .ref-source {
    color: var(--color-text-secondary);
  }

  .ref-count {
    color: var(--color-text-muted);
  }
</style>
