---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { SITE_TITLE, SITE_DESCRIPTION, LINKEDIN_URL } from "../consts";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const hasPosts = allPosts.length > 0 && allPosts[0].data.title !== "Coming Soon";
const featuredPosts = hasPosts ? allPosts.slice(0, 5) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main>
      <!-- Hero -->
      <section class="hero">
        <p class="eyebrow">Karthik Mahalingam</p>
        <h1 class="headline">
          How AI systems fail.<br />
          How to evaluate them.<br />
          How to govern them in production.
        </h1>
        <p class="thesis">
          Essays on agents, evals, safety, privacy, and compliance through the
          lens of distributed systems and real-world engineering.
        </p>
        <div class="hero-actions">
          <a href="/blog" class="btn-primary">Read latest essays</a>
          <a href="/about" class="btn-secondary">Start here</a>
        </div>
      </section>

      <!-- Credibility strip -->
      <section class="proof">
        <div class="proof-grid">
          <div class="proof-item">
            <span class="proof-text">19+ years building distributed systems at scale</span>
          </div>
          <div class="proof-item">
            <span class="proof-text">Engineering leader at Microsoft</span>
          </div>
          <div class="proof-item">
            <span class="proof-text">Writing on AI systems, evals, safety, and governance</span>
          </div>
        </div>
      </section>

      <!-- Featured essays -->
      {featuredPosts.length > 0 && (
        <section class="featured">
          <h2>Featured essays</h2>
          <div class="essay-list">
            {featuredPosts.map((post) => (
              <a href={`/blog/${post.id}/`} class="essay-item">
                <span class="essay-title">{post.data.title}</span>
                {post.data.description && (
                  <span class="essay-summary">{post.data.description}</span>
                )}
                <span class="essay-date">
                  <FormattedDate date={post.data.pubDate} />
                </span>
              </a>
            ))}
          </div>
          <a href="/blog" class="view-all">View all essays &rarr;</a>
        </section>
      )}

      <!-- Topics -->
      <section class="topics">
        <h2>What I write about</h2>
        <div class="topics-grid">
          <div class="topic-card">
            <span class="topic-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="3"/><path d="M12 8v3"/><circle cx="7" cy="16" r="1" fill="#2563eb"/><circle cx="17" cy="16" r="1" fill="#2563eb"/>
              </svg>
            </span>
            <h3>Agents in production</h3>
            <p>How agent systems break, drift, and misbehave once they leave the demo.</p>
          </div>
          <div class="topic-card">
            <span class="topic-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 2h6l-1 7h4l-7 11 1-7H8z"/>
              </svg>
            </span>
            <h3>Evals that catch real failures</h3>
            <p>Practical evaluation strategies for regression detection, reliability, and trust.</p>
          </div>
          <div class="topic-card">
            <span class="topic-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </span>
            <h3>AI safety as systems engineering</h3>
            <p>Safety through control surfaces, guardrails, observability, and failure design.</p>
          </div>
          <div class="topic-card">
            <span class="topic-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </span>
            <h3>Privacy, controls, and compliance</h3>
            <p>How legal and policy obligations become technical architecture and operational workflows.</p>
          </div>
        </div>
      </section>

      <!-- About preview -->
      <section class="about-preview">
        <h2>About</h2>
        <p>
          I write about AI systems from the perspective of someone who has spent
          nearly two decades building large-scale distributed systems. My focus is
          on how agents behave in production, how evaluations can catch real
          failures, and how safety, privacy, and compliance become operational
          reality.
        </p>
        <a href="/about" class="about-link">More about me &rarr;</a>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Hero ── */
  .hero {
    max-width: 720px;
    padding: 3.5rem 0 2.5rem;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    color: #2563eb;
    margin: 0 0 0.75rem;
    font-family: sans-serif;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .headline {
    font-size: clamp(2.25rem, 5.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 1.25rem;
    color: #0f172a;
    letter-spacing: -0.025em;
  }

  .thesis {
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.6;
    color: #475569;
    margin: 0 0 1.75rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: #1e3a8a;
    color: #fff;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.95rem;
    font-family: sans-serif;
    font-weight: 600;
  }

  .btn-primary:hover {
    background: #1e40af;
  }

  .btn-secondary {
    color: #1e293b;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    border: 1px solid #d1d5db;
    text-decoration: none;
    font-size: 0.95rem;
    font-family: sans-serif;
    font-weight: 600;
    background: transparent;
  }

  .btn-secondary:hover {
    border-color: #1e293b;
  }

  /* ── Credibility strip ── */
  .proof {
    padding: 1.5rem 0 2rem;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .proof-text {
    font-family: sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: #64748b;
    line-height: 1.5;
  }

  /* ── Featured essays ── */
  .featured {
    max-width: 860px;
    padding: 3.5rem 0;
    border-bottom: 1px solid #e5e7eb;
  }

  .featured h2 {
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 700;
    margin: 0 0 1.5rem;
    color: #0f172a;
    font-family: sans-serif;
  }

  .essay-list {
    display: flex;
    flex-direction: column;
  }

  .essay-item {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid #f1f5f9;
    text-decoration: none;
    color: inherit;
  }

  .essay-item:last-child {
    border-bottom: none;
  }

  .essay-item:hover .essay-title {
    color: #1e3a8a;
  }

  .essay-title {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 600;
    color: #1e293b;
    font-family: sans-serif;
    line-height: 1.3;
  }

  .essay-summary {
    font-size: 0.95rem;
    color: #64748b;
    line-height: 1.5;
  }

  .essay-date {
    font-size: 0.8rem;
    color: #94a3b8;
    font-family: sans-serif;
  }

  .view-all {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.9rem;
    font-family: sans-serif;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
  }

  .view-all:hover {
    color: #1e3a8a;
  }

  /* ── Topics ── */
  .topics {
    padding: 3.5rem 0;
    border-bottom: 1px solid #e5e7eb;
  }

  .topics h2 {
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 700;
    margin: 0 0 1.5rem;
    color: #0f172a;
    font-family: sans-serif;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .topic-card {
    padding: 1.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    min-width: 0;
  }

  .topic-card:hover {
    border-color: #93c5fd;
  }

  .topic-icon {
    display: block;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .topic-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: #1e293b;
    font-family: sans-serif;
    line-height: 1.3;
  }

  .topic-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #64748b;
    margin: 0;
  }

  /* ── About preview ── */
  .about-preview {
    max-width: 720px;
    padding: 3.5rem 0;
  }

  .about-preview h2 {
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 700;
    margin: 0 0 1rem;
    color: #0f172a;
    font-family: sans-serif;
  }

  .about-preview p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: #475569;
    margin: 0 0 1.25rem;
  }

  .about-link {
    font-size: 0.9rem;
    font-family: sans-serif;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
  }

  .about-link:hover {
    color: #1e3a8a;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    main {
      padding: 0 1.25rem;
    }

    .hero {
      padding: 2.5rem 0 2rem;
    }

    .proof-grid {
      grid-template-columns: 1fr;
      gap: 0.625rem;
    }

    .featured {
      padding: 2.5rem 0;
    }

    .topics {
      padding: 2.5rem 0;
    }

    .topics-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .about-preview {
      padding: 2.5rem 0;
    }
  }

  @media (max-width: 480px) {
    main {
      padding: 0 1rem;
    }

    .hero {
      padding: 2rem 0 1.5rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn-primary,
    .btn-secondary {
      text-align: center;
    }
  }
</style>
