---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, LINKEDIN_URL } from "../consts";
import { getCollection } from "astro:content";
import { getReadingTime } from "../utils/reading-time";

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "LatentMesh",
  "alternateName": "LatentMesh AI",
  "url": SITE_URL + "/",
};

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const hasPosts = allPosts.length > 0 && allPosts[0].data.title !== "Coming Soon";
const latestPosts = hasPosts ? allPosts.slice(0, 6) : [];

// Map first tag to a display category
function getCategory(tags: string[] | undefined): string {
  if (!tags || tags.length === 0) return "Essay";
  const map: Record<string, string> = {
    reliability: "Reliability",
    evals: "Evaluation",
    compliance: "Compliance",
    safety: "Safety",
    evidence: "Evidence",
    practical: "Walkthrough",
    agents: "Agents",
  };
  for (const tag of tags) {
    if (map[tag]) return map[tag];
  }
  return "Essay";
}

function formatMonth(date: Date): string {
  return date.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${SITE_TITLE} | Engineering reliable AI systems`} description={SITE_DESCRIPTION} image="/og-default.png" />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </head>
  <body>
    <Header />

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="hero-content">
          <div class="hero-text">
            <p class="hero-brand">LatentMesh</p>
            <h1>LatentMesh is about engineering reliable AI systems.</h1>
            <p class="hero-sub">Essays and practical frameworks on AI agent failures, evaluation, governance, and production evidence.</p>
            <div class="hero-cta-row">
              <a href="/reading-list" class="btn-primary">Start with the reading list &rarr;</a>
              <a href="/blog" class="btn-secondary">Read latest essays</a>
            </div>
          </div>
          <div class="hero-logo">
            <img src="/favicon.svg" alt="" width="240" height="240" />
          </div>
        </div>
        <p class="hero-credit">LatentMesh by Karthik Mahalingam &middot; 19+ years building distributed systems at scale</p>
      </section>

      <!-- Topics -->
      <section class="topics">
        <div class="topics-inner">
          <div class="section-header">
            <h2>What I write about</h2>
          </div>
          <div class="topic-grid">
            <a href="/topics/agents/" class="topic-cell">
              <div class="topic-icon t-agents">&ofcir;</div>
              <h3>Agent failures</h3>
              <p>How agent systems break, drift, and misbehave once they leave the demo environment.</p>
            </a>
            <a href="/topics/evals/" class="topic-cell">
              <div class="topic-icon t-evals">&target;</div>
              <h3>Evaluation</h3>
              <p>Practical evals for regression, reliability, and operational trust in production.</p>
            </a>
            <a href="/topics/safety/" class="topic-cell">
              <div class="topic-icon t-safety">&osol;</div>
              <h3>Safety</h3>
              <p>Guardrails, control surfaces, observability, containment, and human review loops.</p>
            </a>
            <a href="/topics/compliance/" class="topic-cell">
              <div class="topic-icon t-gov">&equiv;</div>
              <h3>Governance</h3>
              <p>How legal and policy obligations become workflows, controls, and evidence artifacts.</p>
            </a>
          </div>
        </div>
      </section>

      <!-- Start Here: Flagship Essays -->
      <section class="start-here">
        <div class="section-header">
          <h2>Start here</h2>
          <a href="/series" class="view-all-link">View full series &rarr;</a>
        </div>
        <div class="flagship-list">
          <a href="/blog/agent-failures-are-distributed-systems-failures/" class="flagship-item">
            <span class="flagship-num">01</span>
            <div>
              <div class="flagship-title">Agent Failures Are Distributed Systems Failures</div>
              <div class="flagship-desc">The mental models you already have for reliability apply directly to agent systems.</div>
            </div>
          </a>
          <a href="/blog/the-eval-gap/" class="flagship-item">
            <span class="flagship-num">02</span>
            <div>
              <div class="flagship-title">The Eval Gap</div>
              <div class="flagship-desc">Why benchmarks pass in staging and fail in production, and what to measure instead.</div>
            </div>
          </a>
          <a href="/blog/guardrails-are-not-safety/" class="flagship-item">
            <span class="flagship-num">03</span>
            <div>
              <div class="flagship-title">Guardrails Are Not Safety</div>
              <div class="flagship-desc">The difference between filtering outputs and building systems that behave correctly.</div>
            </div>
          </a>
          <a href="/blog/controls-are-not-guardrails/" class="flagship-item">
            <span class="flagship-num">07</span>
            <div>
              <div class="flagship-title">Controls Are Not Guardrails</div>
              <div class="flagship-desc">How engineering controls differ from guardrails, and why compliance requires both.</div>
            </div>
          </a>
          <a href="/blog/anatomy-of-an-evidence-pack/" class="flagship-item">
            <span class="flagship-num">08</span>
            <div>
              <div class="flagship-title">Anatomy of an Evidence Pack</div>
              <div class="flagship-desc">What a production-grade evidence artifact actually looks like for AI compliance.</div>
            </div>
          </a>
        </div>
      </section>

      <!-- Latest Essays -->
      {latestPosts.length > 0 && (
        <section class="latest">
          <div class="section-header">
            <h2>Latest essays</h2>
            <a href="/blog" class="view-all-link">View all &rarr;</a>
          </div>
          <div class="essay-list">
            {latestPosts.map((post) => (
              <a href={`/blog/${post.id}/`} class="essay-item">
                <div>
                  <div class="essay-cat">{getCategory(post.data.tags)}</div>
                  <div class="essay-title">{post.data.title}</div>
                  {post.data.description && (
                    <div class="essay-desc">{post.data.description}</div>
                  )}
                </div>
                <div class="essay-meta-right">
                  <span class="essay-date">{formatMonth(post.data.pubDate)}</span>
                  <span class="essay-read">{getReadingTime(post.body ?? '')} min</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

    </main>

    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
  }

  /* ── Hero ── */
  .hero {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2.5rem 2rem 3rem;
  }

  .hero-content {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3rem;
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  .hero-logo {
    flex-shrink: 0;
    opacity: 0.5;
  }

  .hero-logo img {
    display: block;
    width: 240px;
    height: 240px;
  }

  .hero-brand {
    font-family: sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-link);
    margin: 0 0 0.75rem;
  }

  .hero h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.025em;
    max-width: 720px;
    color: var(--color-text-primary);
    margin: 0;
  }

  .hero-sub {
    margin-top: 1.25rem;
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    max-width: 560px;
    line-height: 1.6;
  }

  .hero-cta-row {
    margin-top: 1.75rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 1.5rem;
    background: var(--color-text-primary);
    color: var(--color-bg);
    font-family: sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.85; }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 1.5rem;
    background: transparent;
    color: var(--color-text-primary);
    font-family: sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--color-text-muted);
    background: var(--color-bg-secondary);
  }

  .hero-credit {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border-light);
    font-size: 0.82rem;
    color: var(--color-text-muted);
    font-family: sans-serif;
  }

  /* ── Topics ── */
  .topics {
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border-light);
    border-bottom: 1px solid var(--color-border-light);
    padding: 4rem 2rem;
  }

  .topics-inner {
    max-width: 1120px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .section-header h2 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
    font-family: sans-serif;
    margin: 0;
  }

  .view-all-link {
    font-size: 0.82rem;
    color: var(--color-link);
    text-decoration: none;
    font-weight: 500;
  }

  .view-all-link:hover { text-decoration: underline; }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border-light);
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    overflow: hidden;
  }

  .topic-cell {
    background: var(--color-bg);
    padding: 2rem 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }

  .topic-cell:hover { background: var(--color-bg-secondary); }

  .topic-icon {
    width: 32px;
    height: 32px;
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .topic-icon.t-agents { background: #fef2f2; color: #dc2626; }
  .topic-icon.t-evals { background: #fffbeb; color: #d97706; }
  .topic-icon.t-safety { background: #eff6ff; color: #2563eb; }
  .topic-icon.t-gov { background: #f0fdf4; color: #16a34a; }

  :global([data-theme="dark"]) .topic-icon.t-agents { background: #3b1515; }
  :global([data-theme="dark"]) .topic-icon.t-evals { background: #3b2e10; }
  :global([data-theme="dark"]) .topic-icon.t-safety { background: #15253b; }
  :global([data-theme="dark"]) .topic-icon.t-gov { background: #153b1f; }

  .topic-cell h3 {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    font-family: sans-serif;
  }

  .topic-cell p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Start Here ── */
  .start-here {
    max-width: 1120px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .flagship-list {
    display: flex;
    flex-direction: column;
  }

  .flagship-item {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border-light);
    text-decoration: none;
    color: inherit;
    transition: all 0.15s;
  }

  .flagship-item:first-child {
    border-top: 1px solid var(--color-border-light);
  }

  .flagship-item:hover {
    background: var(--color-bg-secondary);
    margin: 0 -1rem;
    padding-left: 1rem;
    padding-right: 1rem;
    border-radius: 6px;
  }

  .flagship-num {
    font-family: monospace;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    flex-shrink: 0;
    width: 1.5rem;
  }

  .flagship-title {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.35;
    color: var(--color-text-primary);
  }

  .flagship-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
    line-height: 1.5;
    max-width: 600px;
  }

  /* ── Latest Essays ── */
  .latest {
    max-width: 1120px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .essay-list {
    display: flex;
    flex-direction: column;
  }

  .essay-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--color-border-light);
    text-decoration: none;
    color: inherit;
    align-items: baseline;
    transition: all 0.15s;
  }

  .essay-item:first-child { border-top: 1px solid var(--color-border-light); }

  .essay-item:hover {
    background: var(--color-bg-secondary);
    margin: 0 -1rem;
    padding-left: 1rem;
    padding-right: 1rem;
    border-radius: 6px;
  }

  .essay-cat {
    font-family: monospace;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-link);
    margin-bottom: 0.3rem;
  }

  .essay-title {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.35;
    color: var(--color-text-primary);
  }

  .essay-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-top: 0.3rem;
    line-height: 1.5;
    max-width: 600px;
  }

  .essay-meta-right {
    text-align: right;
    white-space: nowrap;
  }

  .essay-date {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .essay-read {
    display: block;
    font-family: monospace;
    font-size: 0.65rem;
    color: var(--color-text-muted);
    margin-top: 0.2rem;
    letter-spacing: 0.02em;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero { padding: 1.5rem 1.25rem 1.5rem; }
    .topics { padding: 3rem 1.25rem; }
    .start-here { padding: 3rem 1.25rem; }
    .latest { padding: 3rem 1.25rem; }
    .hero-logo { display: none; }
    .topic-grid { grid-template-columns: repeat(2, 1fr); }
    .essay-item { grid-template-columns: 1fr; gap: 0.5rem; }
    .essay-meta-right { text-align: left; display: flex; gap: 0.75rem; }
    .essay-read { display: inline; margin-top: 0; }
  }

  @media (max-width: 480px) {
    .hero { padding: 1.25rem 1rem 1.5rem; }
    .hero h1 { font-size: 1.75rem; line-height: 1.2; }
    .hero-sub { font-size: 0.9rem; margin-top: 0.75rem; }
    .hero-cta-row { margin-top: 1.25rem; }
    .btn-primary, .btn-secondary { text-align: center; justify-content: center; }
    .hero-credit { margin-top: 1.25rem; padding-top: 1rem; }
    .topics { padding: 2.5rem 1rem; }
    .start-here { padding: 2.5rem 1rem; }
    .latest { padding: 2.5rem 1rem; }
    .topic-grid { grid-template-columns: 1fr; }
  }
</style>
