---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main>
      <!-- Hero -->
      <section class="hero">
        <p class="greeting">Hi, I'm Karthik Mahalingam.</p>
        <h1 class="tagline">
          Where distributed systems thinking meets AI risk and safety.
        </h1>
        <p class="intro">
          A seasoned distributed systems architect who spent years designing
          high-scale infrastructure, now applying that same systems thinking to
          AI risk, safety, and governance at Microsoft. This is where I think in
          public about agents, evals, compliance, trust, and the hard problems
          that don't have clean answers yet.
        </p>
        <p class="credibility">
          19+ years building high-scale distributed systems. Now at Microsoft,
          spanning agent identity, privacy-by-design, AI system evaluations,
          and responsible AI guardrails.
        </p>
        <div class="hero-links">
          <a href="/blog" class="btn-primary">Read the blog</a>
          <a href="/about" class="btn-secondary">About me</a>
        </div>
      </section>

      <!-- Topics -->
      <section class="topics">
        <h2>What I write about</h2>
        <div class="topics-grid">
          <div class="topic-card">
            <span class="topic-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="3"/><path d="M12 8v3"/><circle cx="7" cy="16" r="1" fill="#2563eb"/><circle cx="17" cy="16" r="1" fill="#2563eb"/>
              </svg>
            </span>
            <h3>AI Agents</h3>
            <p>
              Governance, identity, autonomy, and what happens when agents
              interact at scale.
            </p>
          </div>
          <div class="topic-card">
            <span class="topic-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 2h6l-1 7h4l-7 11 1-7H8z"/>
              </svg>
            </span>
            <h3>AI System Evals</h3>
            <p>
              How to measure, test, and validate AI systems before and after
              deployment.
            </p>
          </div>
          <div class="topic-card">
            <span class="topic-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </span>
            <h3>AI Safety</h3>
            <p>
              Alignment, robustness, failure modes, and building systems that
              behave as intended.
            </p>
          </div>
          <div class="topic-card">
            <span class="topic-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </span>
            <h3>Privacy and Compliance</h3>
            <p>GDPR, DMA, least-privilege, and regulatory realities.</p>
          </div>
          <div class="topic-card">
            <span class="topic-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/><circle cx="4" cy="6" r="2"/><circle cx="20" cy="6" r="2"/><circle cx="4" cy="18" r="2"/><circle cx="20" cy="18" r="2"/><line x1="6" y1="6" x2="9.5" y2="10"/><line x1="18" y1="6" x2="14.5" y2="10"/><line x1="6" y1="18" x2="9.5" y2="14"/><line x1="18" y1="18" x2="14.5" y2="14"/>
              </svg>
            </span>
            <h3>Distributed Systems</h3>
            <p>
              Hard-won patterns from building at scale, now applied to AI
              infrastructure.
            </p>
          </div>
          <div class="topic-card">
            <span class="topic-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
              </svg>
            </span>
            <h3>Field Notes</h3>
            <p>
              Observations from the frontier of responsible AI in big tech.
            </p>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  /* Hero */
  .hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid #eee;
  }

  .greeting {
    font-size: 1rem;
    color: #666;
    margin: 0 0 0.5rem;
    font-family: monospace;
  }

  .tagline {
    font-size: clamp(1.35rem, 4.5vw, 2rem);
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 1.25rem;
    color: #111;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .intro {
    font-size: 1.1rem;
    line-height: 1.75;
    color: #444;
    margin: 0 0 1.25rem;
    max-width: 640px;
  }

  .credibility {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #777;
    margin: 0 0 2rem;
    padding: 0.75rem 1rem;
    border-left: 3px solid #dbeafe;
    background: #f8fafc;
    border-radius: 0 4px 4px 0;
  }

  .hero-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: #111;
    color: #fff;
    padding: 0.6rem 1.4rem;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.95rem;
    font-family: sans-serif;
  }

  .btn-primary:hover {
    background: #333;
  }

  .btn-secondary {
    color: #111;
    padding: 0.6rem 1.4rem;
    border-radius: 4px;
    border: 1px solid #ccc;
    text-decoration: none;
    font-size: 0.95rem;
    font-family: sans-serif;
  }

  .btn-secondary:hover {
    border-color: #111;
  }

  /* Topics */
  .topics {
    padding: 3rem 0 4rem;
  }

  .topics h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 2rem;
    color: #111;
    font-family: sans-serif;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .topic-card {
    padding: 1rem;
    border: 1px solid #eee;
    border-radius: 6px;
    min-width: 0;
  }

  .topic-card:hover {
    border-color: #ccc;
  }

  .topic-icon {
    display: block;
    margin-bottom: 0.75rem;
    line-height: 1;
  }

  .topic-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: #111;
    font-family: sans-serif;
  }

  .topic-card p {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #666;
    margin: 0;
    overflow-wrap: break-word;
  }

  @media (max-width: 720px) {
    .topics-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .hero {
      padding: 1.5rem 0;
    }
  }
</style>
