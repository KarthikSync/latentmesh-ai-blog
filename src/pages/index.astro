---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import EmailSignup from "../components/EmailSignup.astro";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, SITE_AUTHOR, LINKEDIN_URL, GITHUB_URL } from "../consts";
import { getCollection } from "astro:content";
import { getReadingTime } from "../utils/reading-time";

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "LatentMesh",
  "alternateName": "LatentMesh AI",
  "url": SITE_URL + "/",
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "LatentMesh",
  "url": SITE_URL + "/",
  "description": SITE_DESCRIPTION,
  "founder": { "@type": "Person", "name": SITE_AUTHOR, "url": SITE_URL + "/about/" },
  "sameAs": [LINKEDIN_URL, GITHUB_URL],
};

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const hasPosts = allPosts.length > 0 && allPosts[0].data.title !== "Coming Soon";
const latestPosts = hasPosts ? allPosts.slice(0, 6) : [];

// Map first tag to a display category
function getCategory(tags: string[] | undefined): string {
  if (!tags || tags.length === 0) return "Essay";
  const map: Record<string, string> = {
    reliability: "Reliability",
    evals: "Evaluation",
    compliance: "Compliance",
    safety: "Safety",
    evidence: "Evidence",
    practical: "Walkthrough",
    agents: "Agents",
  };
  for (const tag of tags) {
    if (map[tag]) return map[tag];
  }
  return "Essay";
}

function formatMonth(date: Date): string {
  return date.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${SITE_TITLE} | AI compliance, evaluation, and governance`} description={SITE_DESCRIPTION} image="/og-default.png" />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </head>
  <body>
    <Header />

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="hero-content">
          <div class="hero-text">
            <p class="hero-brand">LatentMesh</p>
            <h1>Practical engineering for AI compliance, AI evaluation, and governance.</h1>
            <p class="hero-sub">Essays and frameworks on AI regulatory compliance, agent failures, controls, and production evidence.</p>
            <div class="hero-cta-row">
              <a href="/reading-list" class="btn-primary" onclick="gtag('event','cta_click',{cta_name:'reading_list',location:'homepage_hero'})">Start with the reading list &rarr;</a>
              <a href="/blog" class="btn-secondary" onclick="gtag('event','cta_click',{cta_name:'latest_essays',location:'homepage_hero'})">Latest essays</a>
            </div>
          </div>
          <div class="hero-panel">
            <img src="/images/right-panel.png" alt="Evidence loop: Obligation, Control, Eval, Evidence — with coverage and verification status" width="380" height="420" />
          </div>
        </div>
        <div class="proof-card">
          <p class="proof-title">From obligation to proof</p>
          <div class="proof-flow">
            <div class="proof-row">
              <span class="proof-step"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg> Obligation</span>
              <span class="proof-arrow">&rarr;</span>
              <span class="proof-step"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Control</span>
            </div>
            <div class="proof-row">
              <span class="proof-step"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><polyline points="9 11 12 14 22 4"/></svg> Eval</span>
              <span class="proof-arrow">&rarr;</span>
              <span class="proof-step"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg> Evidence</span>
            </div>
          </div>
        </div>
        <p class="hero-credit">LatentMesh by Karthik Mahalingam &middot; 19+ years building distributed systems at scale</p>
      </section>

      <!-- Topics -->
      <section class="topics">
        <div class="topics-inner">
          <div class="section-header">
            <h2>What I write about</h2>
          </div>
          <div class="topic-grid">
            <a href="/topics/agents/" class="topic-cell" onclick="gtag('event','topic_click',{topic:'agents'})">
              <div class="topic-icon t-agents">&ofcir;</div>
              <h3>Agent failures</h3>
              <p>How agent systems break, drift, and misbehave once they leave the demo environment.</p>
            </a>
            <a href="/topics/evals/" class="topic-cell" onclick="gtag('event','topic_click',{topic:'evals'})">
              <div class="topic-icon t-evals">&target;</div>
              <h3>Evaluation</h3>
              <p>Practical evals for regression, reliability, and operational trust in production.</p>
            </a>
            <a href="/topics/safety/" class="topic-cell" onclick="gtag('event','topic_click',{topic:'safety'})">
              <div class="topic-icon t-safety">&osol;</div>
              <h3>Safety</h3>
              <p>Guardrails, control surfaces, observability, containment, and human review loops.</p>
            </a>
            <a href="/ai-compliance/" class="topic-cell" onclick="gtag('event','topic_click',{topic:'ai_compliance'})">
              <div class="topic-icon t-gov">&equiv;</div>
              <h3>AI compliance</h3>
              <p>How regulatory obligations become engineering controls, evaluations, and audit-ready evidence.</p>
            </a>
          </div>
        </div>
      </section>

      <!-- Start Here: Flagship Essays -->
      <section class="start-here">
        <div class="section-header">
          <h2>Start here</h2>
          <a href="/series" class="view-all-link">View full series &rarr;</a>
        </div>
        <div class="flagship-list">
          <a href="/blog/agent-failures-are-distributed-systems-failures/" class="flagship-item" onclick="gtag('event','essay_click',{essay:'agent-failures',section:'start_here'})">
            <span class="flagship-num">01</span>
            <div>
              <div class="flagship-title">Agent Failures Are Distributed Systems Failures</div>
              <div class="flagship-desc">The mental models you already have for reliability apply directly to agent systems.</div>
            </div>
          </a>
          <a href="/blog/the-eval-gap/" class="flagship-item" onclick="gtag('event','essay_click',{essay:'eval-gap',section:'start_here'})">
            <span class="flagship-num">02</span>
            <div>
              <div class="flagship-title">The Eval Gap</div>
              <div class="flagship-desc">Why benchmarks pass in staging and fail in production, and what to measure instead.</div>
            </div>
          </a>
          <a href="/blog/guardrails-are-not-safety/" class="flagship-item" onclick="gtag('event','essay_click',{essay:'guardrails-not-safety',section:'start_here'})">
            <span class="flagship-num">03</span>
            <div>
              <div class="flagship-title">Guardrails Are Not Safety</div>
              <div class="flagship-desc">The difference between filtering outputs and building systems that behave correctly.</div>
            </div>
          </a>
          <a href="/blog/controls-are-not-guardrails/" class="flagship-item" onclick="gtag('event','essay_click',{essay:'controls-not-guardrails',section:'start_here'})">
            <span class="flagship-num">07</span>
            <div>
              <div class="flagship-title">Controls Are Not Guardrails</div>
              <div class="flagship-desc">How engineering controls differ from guardrails, and why compliance requires both.</div>
            </div>
          </a>
          <a href="/blog/anatomy-of-an-evidence-pack/" class="flagship-item" onclick="gtag('event','essay_click',{essay:'evidence-pack',section:'start_here'})">
            <span class="flagship-num">08</span>
            <div>
              <div class="flagship-title">Anatomy of an Evidence Pack</div>
              <div class="flagship-desc">What a production-grade evidence artifact actually looks like for AI compliance.</div>
            </div>
          </a>
        </div>
      </section>

      <EmailSignup
        variant="section"
        heading="Stay in the loop"
        body="A weekly note on building reliable AI systems: governance, evals, controls, and compliance."
      />

      <!-- Latest Essays -->
      {latestPosts.length > 0 && (
        <section class="latest">
          <div class="section-header">
            <h2>Latest essays</h2>
            <a href="/blog" class="view-all-link">View all &rarr;</a>
          </div>
          <div class="essay-list">
            {latestPosts.map((post) => (
              <a href={`/blog/${post.id}/`} class="essay-item">
                <div>
                  <div class="essay-cat">{getCategory(post.data.tags)}</div>
                  <div class="essay-title">{post.data.title}</div>
                  {post.data.description && (
                    <div class="essay-desc">{post.data.description}</div>
                  )}
                </div>
                <div class="essay-meta-right">
                  <span class="essay-date">{formatMonth(post.data.pubDate)}</span>
                  <span class="essay-read">{getReadingTime(post.body ?? '')} min</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <EmailSignup
        variant="section"
        heading="Stay in the loop"
        body="A weekly note on building reliable AI systems: governance, evals, controls, and compliance."
      />

    </main>

    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
  }

  /* ── Hero ── */
  .hero {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2.5rem 2rem 3rem;
  }

  .hero-content {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3rem;
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  .hero-panel {
    flex-shrink: 0;
    position: relative;
    filter: drop-shadow(0 4px 24px rgba(59, 93, 140, 0.08));
  }

  .hero-panel img {
    display: block;
    width: 340px;
    height: auto;
    border-radius: 12px;
  }

  .proof-card {
    display: none;
    max-width: 360px;
    margin-top: 1.5rem;
    padding: 0.9rem 1.25rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(59, 93, 140, 0.06);
    text-align: center;
  }

  .proof-title {
    font-family: sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.6rem;
    letter-spacing: -0.01em;
  }

  .proof-flow {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.5rem 0.75rem;
    background: #e8ecf3;
    border-radius: 8px;
  }

  :global([data-theme="dark"]) .proof-flow {
    background: #1e2536;
  }

  .proof-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .proof-step {
    font-family: sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-primary);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    white-space: nowrap;
  }

  .proof-step svg {
    color: #3b6cb5;
    flex-shrink: 0;
  }

  :global([data-theme="dark"]) .proof-step svg {
    color: #6b9fe8;
  }

  .proof-arrow {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .hero-brand {
    font-family: sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-link);
    margin: 0 0 0.75rem;
  }

  .hero h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.025em;
    max-width: 720px;
    color: var(--color-text-primary);
    margin: 0;
  }

  .hero-sub {
    margin-top: 1.25rem;
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    max-width: 560px;
    line-height: 1.6;
  }

  .hero-cta-row {
    margin-top: 1.75rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 1.5rem;
    background: var(--color-text-primary);
    color: var(--color-bg);
    font-family: sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.85; }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 1.5rem;
    background: transparent;
    color: var(--color-text-primary);
    font-family: sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--color-text-muted);
    background: var(--color-bg-secondary);
  }

  .hero-credit {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border-light);
    font-size: 0.82rem;
    color: var(--color-text-muted);
    font-family: sans-serif;
  }

  /* ── Topics ── */
  .topics {
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border-light);
    border-bottom: 1px solid var(--color-border-light);
    padding: 4rem 2rem;
  }

  .topics-inner {
    max-width: 1120px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .section-header h2 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
    font-family: sans-serif;
    margin: 0;
  }

  .view-all-link {
    font-size: 0.82rem;
    color: var(--color-link);
    text-decoration: none;
    font-weight: 500;
  }

  .view-all-link:hover { text-decoration: underline; }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border-light);
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    overflow: hidden;
  }

  .topic-cell {
    background: var(--color-bg);
    padding: 2rem 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }

  .topic-cell:hover { background: var(--color-bg-secondary); }

  .topic-icon {
    width: 32px;
    height: 32px;
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .topic-icon.t-agents { background: #fef2f2; color: #dc2626; }
  .topic-icon.t-evals { background: #fffbeb; color: #d97706; }
  .topic-icon.t-safety { background: #eff6ff; color: #2563eb; }
  .topic-icon.t-gov { background: #f0fdf4; color: #16a34a; }

  :global([data-theme="dark"]) .topic-icon.t-agents { background: #3b1515; }
  :global([data-theme="dark"]) .topic-icon.t-evals { background: #3b2e10; }
  :global([data-theme="dark"]) .topic-icon.t-safety { background: #15253b; }
  :global([data-theme="dark"]) .topic-icon.t-gov { background: #153b1f; }

  .topic-cell h3 {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    font-family: sans-serif;
  }

  .topic-cell p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Start Here ── */
  .start-here {
    max-width: 1120px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .flagship-list {
    display: flex;
    flex-direction: column;
  }

  .flagship-item {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border-light);
    text-decoration: none;
    color: inherit;
    transition: all 0.15s;
  }

  .flagship-item:first-child {
    border-top: 1px solid var(--color-border-light);
  }

  .flagship-item:hover {
    background: var(--color-bg-secondary);
    margin: 0 -1rem;
    padding-left: 1rem;
    padding-right: 1rem;
    border-radius: 6px;
  }

  .flagship-num {
    font-family: monospace;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    flex-shrink: 0;
    width: 1.5rem;
  }

  .flagship-title {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.35;
    color: var(--color-text-primary);
  }

  .flagship-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
    line-height: 1.5;
    max-width: 600px;
  }

  /* ── Latest Essays ── */
  .latest {
    max-width: 1120px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .essay-list {
    display: flex;
    flex-direction: column;
  }

  .essay-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--color-border-light);
    text-decoration: none;
    color: inherit;
    align-items: baseline;
    transition: all 0.15s;
  }

  .essay-item:first-child { border-top: 1px solid var(--color-border-light); }

  .essay-item:hover {
    background: var(--color-bg-secondary);
    margin: 0 -1rem;
    padding-left: 1rem;
    padding-right: 1rem;
    border-radius: 6px;
  }

  .essay-cat {
    font-family: monospace;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-link);
    margin-bottom: 0.3rem;
  }

  .essay-title {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.35;
    color: var(--color-text-primary);
  }

  .essay-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-top: 0.3rem;
    line-height: 1.5;
    max-width: 600px;
  }

  .essay-meta-right {
    text-align: right;
    white-space: nowrap;
  }

  .essay-date {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .essay-read {
    display: block;
    font-family: monospace;
    font-size: 0.65rem;
    color: var(--color-text-muted);
    margin-top: 0.2rem;
    letter-spacing: 0.02em;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero { padding: 1.5rem 1.25rem 1.5rem; }
    .topics { padding: 3rem 1.25rem; }
    .start-here { padding: 3rem 1.25rem; }
    .latest { padding: 3rem 1.25rem; }
    .hero-content { flex-direction: column; gap: 2rem; }
    .hero-panel { align-self: center; }
    .hero-panel img { width: 280px; }
    .topic-grid { grid-template-columns: repeat(2, 1fr); }
    .essay-item { grid-template-columns: 1fr; gap: 0.5rem; }
    .essay-meta-right { text-align: left; display: flex; gap: 0.75rem; }
    .essay-read { display: inline; margin-top: 0; }
  }

  @media (max-width: 480px) {
    .hero { padding: 1.25rem 1rem 2rem; }
    .hero-panel { display: none; }
    .proof-card {
      display: block;
      margin-top: 1.5rem;
    }
    .hero h1 { font-size: 1.75rem; line-height: 1.2; }
    .hero-sub { font-size: 0.9rem; margin-top: 0.75rem; }
    .hero-cta-row { margin-top: 1.25rem; gap: 0.65rem; flex-wrap: nowrap; }
    .btn-primary { font-size: 0.78rem; padding: 0.55rem 1.1rem; border-radius: 5px; }
    .btn-secondary { font-size: 0.78rem; padding: 0.55rem 1.25rem; border-radius: 5px; }
    .hero-credit { margin-top: 1.5rem; padding-top: 1rem; padding-bottom: 0.25rem; }
    .topics { display: none; }
    .start-here { padding: 2.5rem 1rem; }
    .flagship-item:nth-child(n+4) { display: none; }
    .latest { padding: 2.5rem 1rem; }
    .essay-item:nth-child(n+4) { display: none; }
  }
</style>
