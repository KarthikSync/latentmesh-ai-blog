---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const hasPosts = allPosts.length > 0 && allPosts[0].data.title !== "Coming Soon";
const latestPosts = hasPosts ? allPosts.slice(0, 6) : [];

const startHereEssays = [
  {
    slug: "agent-failures-are-distributed-systems-failures",
    title: "Agent Failures Are Distributed Systems Failures",
    summary: "Why agent failures are usually system failures, not just model failures.",
  },
  {
    slug: "the-eval-gap",
    title: "The Eval Gap",
    summary: "Why staging success does not predict production reliability.",
  },
  {
    slug: "controls-are-not-guardrails",
    title: "Controls Are Not Guardrails",
    summary: "Why runtime safety layers are not enough without evidence, ownership, and testing.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image="/og-default.png" />
  </head>
  <body>
    <Header />

    <main>
      <!-- Hero -->
      <section class="hero">
        <p class="eyebrow">Karthik Mahalingam writing at LatentMesh</p>
        <h1 class="headline">
          How AI systems fail.<br />
          How to evaluate them.<br />
          How to govern them in production.
        </h1>
        <p class="thesis">
          Most AI governance advice skips the engineering. These essays don't.
        </p>
        <div class="hero-actions">
          <a href="/blog" class="btn-primary">Read latest essays</a>
          <a href="#start-here" class="btn-secondary">Start with the series</a>
        </div>
      </section>

      <!-- Credibility strip -->
      <section class="proof">
        <div class="proof-grid">
          <div class="proof-item">
            <span class="proof-text">19+ years building distributed systems at scale</span>
          </div>
          <div class="proof-item">
            <span class="proof-text">Engineering leader at Microsoft</span>
          </div>
          <div class="proof-item">
            <span class="proof-text">Writing on AI systems, evals, safety, and governance</span>
          </div>
        </div>
      </section>

      <!-- Start here -->
      <section class="start-here" id="start-here">
        <p class="series-label">Series: Reliable Agent Systems &middot; Nine essays</p>
        <h2>Start here</h2>
        <p class="section-intro">New to LatentMesh? Start with the core essay series on how agent systems fail, how to evaluate them in the real world, and how governance becomes operational.</p>
        <div class="start-here-grid">
          {startHereEssays.map((essay) => (
            <a href={`/blog/${essay.slug}/`} class="start-here-card">
              <h3>{essay.title}</h3>
              <p>{essay.summary}</p>
            </a>
          ))}
        </div>
        <a href="/blog/agent-failures-are-distributed-systems-failures/" class="view-all">Read the series &rarr;</a>
      </section>

      <!-- Latest essays -->
      {latestPosts.length > 0 && (
        <section class="featured">
          <h2>Latest essays</h2>
          <p class="section-intro">Recent essays on agent reliability, evaluation, safety, and governance.</p>
          <div class="essay-list">
            {latestPosts.map((post) => (
              <a href={`/blog/${post.id}/`} class="essay-item">
                <span class="essay-title">{post.data.title}</span>
                {post.data.description && (
                  <span class="essay-summary">{post.data.description}</span>
                )}
                <span class="essay-date">
                  <FormattedDate date={post.data.pubDate} />
                </span>
              </a>
            ))}
          </div>
          <a href="/blog" class="view-all">View all essays &rarr;</a>
        </section>
      )}

      <!-- Topics -->
      <section class="topics">
        <h2>What I write about</h2>
        <div class="topics-grid">
          <a href="/topics/agents/" class="topic-card">
            <span class="topic-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="3"/><path d="M12 8v3"/><circle cx="7" cy="16" r="1" fill="#2563eb"/><circle cx="17" cy="16" r="1" fill="#2563eb"/>
              </svg>
            </span>
            <h3>Agent failure as system failure</h3>
            <p>How agent systems break, drift, and misbehave once they leave the demo.</p>
          </a>
          <a href="/topics/evals/" class="topic-card">
            <span class="topic-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 2h6l-1 7h4l-7 11 1-7H8z"/>
              </svg>
            </span>
            <h3>Evaluation that catches real failures</h3>
            <p>Practical evals for regression, reliability, and operational trust.</p>
          </a>
          <a href="/topics/safety/" class="topic-card">
            <span class="topic-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </span>
            <h3>Safety as systems engineering</h3>
            <p>Guardrails, control surfaces, observability, containment, and human review.</p>
          </a>
          <a href="/topics/compliance/" class="topic-card">
            <span class="topic-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </span>
            <h3>Compliance that becomes architecture</h3>
            <p>How legal and policy obligations turn into workflows, controls, and evidence.</p>
          </a>
        </div>
      </section>

      <!-- About preview -->
      <section class="about-preview">
        <h2>About</h2>
        <p>
          I write about AI systems from the perspective of someone who has spent
          nearly two decades building large-scale distributed systems. My focus is
          on how agents behave in production, how evaluations catch real
          failures, and how safety, privacy, and compliance become operational
          reality.
        </p>
        <a href="/about" class="about-link">More about me &rarr;</a>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Hero ── */
  .hero {
    max-width: 720px;
    padding: 2.5rem 0 2rem;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-link);
    margin: 0 0 0.75rem;
    font-family: sans-serif;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .headline {
    font-size: clamp(2.25rem, 5.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 1.25rem;
    color: var(--color-text-primary);
    letter-spacing: -0.025em;
  }

  .thesis {
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0 0 1.75rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--color-brand);
    color: #fff;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.95rem;
    font-family: sans-serif;
    font-weight: 600;
  }

  .btn-primary:hover {
    background: var(--color-brand-hover);
  }

  .btn-secondary {
    color: var(--color-text-primary);
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    text-decoration: none;
    font-size: 0.95rem;
    font-family: sans-serif;
    font-weight: 600;
    background: transparent;
  }

  .btn-secondary:hover {
    border-color: var(--color-text-primary);
  }

  /* ── Credibility strip ── */
  .proof {
    padding: 1.25rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .proof-text {
    font-family: sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* ── Section intro ── */
  .section-intro {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0 0 1.5rem;
    max-width: 640px;
  }

  /* ── Start here ── */
  .start-here {
    max-width: 860px;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .start-here h2 {
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 700;
    margin: 0 0 0.75rem;
    color: var(--color-text-primary);
    font-family: sans-serif;
  }

  .start-here-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .start-here-card {
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .start-here-card:hover {
    border-color: var(--color-card-hover);
  }

  .start-here-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--color-text-primary);
    font-family: sans-serif;
    line-height: 1.3;
  }

  .start-here-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .series-label {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-link);
    margin: 0 0 0.25rem;
    font-family: sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ── Latest essays ── */
  .featured {
    max-width: 860px;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .featured h2 {
    font-size: clamp(1.25rem, 3vw, 1.5rem);
    font-weight: 800;
    margin: 0 0 0.5rem;
    color: var(--color-text-primary);
    font-family: sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .essay-list {
    display: flex;
    flex-direction: column;
  }

  .essay-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.5rem;
    border-left: 3px solid var(--color-link);
    background: var(--color-bg-secondary);
    border-radius: 0 8px 8px 0;
    margin-bottom: 1rem;
    text-decoration: none;
    color: inherit;
  }

  .essay-item:hover {
    border-left-color: var(--color-brand);
  }

  .essay-item:hover .essay-title {
    color: var(--color-brand);
  }

  .essay-title {
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    font-weight: 700;
    color: var(--color-text-primary);
    font-family: sans-serif;
    line-height: 1.3;
  }

  .essay-summary {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .essay-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-family: sans-serif;
  }

  .view-all {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.9rem;
    font-family: sans-serif;
    font-weight: 600;
    color: var(--color-link);
    text-decoration: none;
  }

  .view-all:hover {
    color: var(--color-brand);
  }

  /* ── Topics ── */
  .topics {
    padding: 3.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .topics h2 {
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 700;
    margin: 0 0 1.5rem;
    color: var(--color-text-primary);
    font-family: sans-serif;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .topic-card {
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    min-width: 0;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .topic-card:hover {
    border-color: var(--color-card-hover);
  }

  .topic-icon {
    display: block;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .topic-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--color-text-primary);
    font-family: sans-serif;
    line-height: 1.3;
  }

  .topic-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ── About preview ── */
  .about-preview {
    max-width: 720px;
    padding: 3.5rem 0;
  }

  .about-preview h2 {
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 700;
    margin: 0 0 1rem;
    color: var(--color-text-primary);
    font-family: sans-serif;
  }

  .about-preview p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0 0 1.25rem;
  }

  .about-link {
    font-size: 0.9rem;
    font-family: sans-serif;
    font-weight: 600;
    color: var(--color-link);
    text-decoration: none;
  }

  .about-link:hover {
    color: var(--color-brand);
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    main {
      padding: 0 1.25rem;
    }

    .hero {
      padding: 1.5rem 0 1.25rem;
    }

    .proof-grid {
      grid-template-columns: 1fr;
      gap: 0.625rem;
    }

    .start-here {
      padding: 2.5rem 0;
    }

    .start-here-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .featured {
      padding: 2.5rem 0;
    }

    .topics {
      padding: 2.5rem 0;
    }

    .topics-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .about-preview {
      padding: 2.5rem 0;
    }
  }

  @media (max-width: 480px) {
    main {
      padding: 0 1rem;
    }

    .hero {
      padding: 1.25rem 0 1rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn-primary,
    .btn-secondary {
      text-align: center;
    }
  }
</style>
