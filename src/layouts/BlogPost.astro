---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'] & { slug: string; readingTime?: number; tags?: string[] };

const { title, description, pubDate, updatedDate, heroImage, slug, readingTime, tags } = Astro.props;
const pageUrl = new URL(`/blog/${slug}/`, Astro.site).toString();

// Series data — ordered reading list
const seriesEssays = [
	{ slug: "agent-failures-are-distributed-systems-failures", title: "Agent Failures Are Distributed Systems Failures" },
	{ slug: "the-eval-gap", title: "The Eval Gap" },
	{ slug: "guardrails-are-not-safety", title: "Guardrails Are Not Safety" },
	{ slug: "who-owns-the-agents-mistake", title: "Who Owns the Agent\u2019s Mistake?" },
	{ slug: "drift-is-the-default", title: "Drift Is the Default" },
	{ slug: "what-should-an-ai-system-actually-prove", title: "What Should an AI System Actually Prove?" },
	{ slug: "controls-are-not-guardrails", title: "Controls Are Not Guardrails" },
	{ slug: "anatomy-of-an-evidence-pack", title: "Anatomy of an Evidence Pack" },
	{ slug: "mapping-the-eu-ai-act-to-engineering-evidence", title: "Mapping the EU AI Act to Engineering Evidence" },
	{ slug: "the-incident-response-gap-in-ai-systems", title: "The Incident Response Gap in AI Systems" },
];

const seriesIndex = seriesEssays.findIndex((e) => e.slug === slug);
const isInSeries = seriesIndex !== -1;
const prevEssay = isInSeries && seriesIndex > 0 ? seriesEssays[seriesIndex - 1] : null;
const nextEssay = isInSeries && seriesIndex < seriesEssays.length - 1 ? seriesEssays[seriesIndex + 1] : null;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image="/og-default.png" type="article" pubDate={pubDate} />
	</head>

	<body>
		<Header />
		<main>
			<article data-slug={slug} data-url={pageUrl} data-title={title}>
				<!-- Back to Essays -->
				<a href="/blog" class="back-link">&larr; Back to Essays</a>

				{heroImage && (
					<div class="hero-image">
						<img width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose">
					<header class="essay-header">
						<span class="date">
							<FormattedDate date={pubDate} />
							{readingTime && <span>&middot; {readingTime} min read</span>}
							<span class="view-count" id="view-count"></span>
							{
								updatedDate && (
									<span class="last-updated-on">
										&middot; Updated <FormattedDate date={updatedDate} />
									</span>
								)
							}
						</span>
						<h1>{title}</h1>
						{description && (
							<p class="dek">{description}</p>
						)}
						{tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => (
									<a href={`/topics/${tag}/`} class="tag"># {tag}</a>
								))}
							</div>
						)}
					</header>

					<!-- Series navigation block -->
					{isInSeries && (
						<nav class="series-nav" aria-label="Essay series navigation">
							<div class="series-nav-header">
								<span class="series-label">Series: Reliable Agent Systems</span>
								<span class="series-position">Essay {seriesIndex + 1} of {seriesEssays.length}</span>
							</div>
							<p class="series-description">This series explores how AI systems fail, how to evaluate them in production, and how governance becomes operational through controls, evidence, and accountability.</p>
							<details class="series-reading-order">
								<summary>Reading order</summary>
								<ol>
									{seriesEssays.map((essay, i) => (
										<li class={essay.slug === slug ? "current" : ""}>
											{essay.slug === slug ? (
												<span>{essay.title}</span>
											) : (
												<a href={`/blog/${essay.slug}/`}>{essay.title}</a>
											)}
										</li>
									))}
								</ol>
							</details>
						</nav>
					)}

					<slot />

					<!-- End-of-essay block -->
					<footer class="essay-footer">
						<div class="share-links">
							<span class="share-label">Share</span>
							<button id="native-share" class="share-icon" style="display:none" aria-label="Share this essay">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
							</button>
							<div id="social-share" class="social-buttons">
								<a class="share-icon"
									href={`https://x.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(title)}`}
									target="_blank" rel="noopener noreferrer" aria-label="Share on X">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
								</a>
								<a class="share-icon"
									href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`}
									target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
								</a>
								<button class="share-icon" id="copy-link" aria-label="Copy link" title="Copy link">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
								</button>
							</div>
						</div>

						<!-- Continue reading -->
						{isInSeries && (
							<section class="continue-reading">
								<h2>Continue reading</h2>
								<div class="prev-next">
									{prevEssay && (
										<a href={`/blog/${prevEssay.slug}/`} class="prev-next-link prev">
											<span class="prev-next-label">&larr; Previous</span>
											<span class="prev-next-title">{prevEssay.title}</span>
										</a>
									)}
									{nextEssay && (
										<a href={`/blog/${nextEssay.slug}/`} class="prev-next-link next">
											<span class="prev-next-label">Next &rarr;</span>
											<span class="prev-next-title">{nextEssay.title}</span>
										</a>
									)}
								</div>
								<p class="series-entry">New here? <a href="/blog/agent-failures-are-distributed-systems-failures/">Start from the beginning</a> of the Reliable Agent Systems series.</p>
							</section>
						)}

						<!-- Email capture -->
						<div class="email-capture">
							<p class="email-capture-label">Follow on LinkedIn for new essays — email signup coming soon.</p>
							<a href="https://www.linkedin.com/in/karthiksync" target="_blank" rel="noopener noreferrer" class="email-capture-cta">Follow on LinkedIn</a>
						</div>

						<!-- Reader feedback -->
						<div class="reader-feedback" id="reader-feedback">
							<p class="feedback-prompt">Was this essay useful?</p>
							<div class="feedback-options">
								<button class="feedback-btn" data-value="very">Very useful</button>
								<button class="feedback-btn" data-value="somewhat">Somewhat useful</button>
								<button class="feedback-btn" data-value="not">Not useful</button>
							</div>
							<div class="feedback-followup" id="feedback-followup" style="display:none">
								<label for="feedback-text" class="feedback-text-label">What would have made it more useful?</label>
								<textarea id="feedback-text" class="feedback-textarea" rows="2" placeholder="Optional"></textarea>
								<button class="feedback-submit" id="feedback-submit">Send</button>
							</div>
							<p class="feedback-thanks" id="feedback-thanks" style="display:none">Thanks for the feedback.</p>
						</div>
					</footer>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<script>
	const article = document.querySelector('article[data-slug]');
	const slug = article?.getAttribute('data-slug');
	const url = article?.getAttribute('data-url') ?? '';
	const title = article?.getAttribute('data-title') ?? '';

	// View count
	if (slug) {
		fetch(`/api/views/${slug}`, {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({
				referrer: document.referrer,
				utmSource: new URLSearchParams(window.location.search).get('utm_source'),
			}),
		})
			.then(r => r.json())
			.then(data => {
				const el = document.getElementById('view-count');
				if (el && data.views > 0) {
					el.textContent = ` \u00b7 ${data.views} view${data.views === 1 ? '' : 's'}`;
				}
			})
			.catch(() => {});
	}

	// Share links
	const nativeBtn = document.getElementById('native-share');
	const socialDiv = document.getElementById('social-share');

	if (navigator.share) {
		if (nativeBtn) nativeBtn.style.display = 'inline-flex';
		if (socialDiv) socialDiv.style.display = 'none';

		nativeBtn?.addEventListener('click', () => {
			navigator.share({ title, url }).catch(() => {});
		});
	}

	// Copy link
	document.getElementById('copy-link')?.addEventListener('click', () => {
		navigator.clipboard.writeText(url).then(() => {
			const btn = document.getElementById('copy-link');
			if (btn) {
				btn.setAttribute('title', 'Copied!');
				setTimeout(() => { btn.setAttribute('title', 'Copy link'); }, 2000);
			}
		});
	});

	// Reader feedback
	document.querySelectorAll('.feedback-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			document.querySelectorAll('.feedback-btn').forEach((b) => b.classList.remove('selected'));
			btn.classList.add('selected');
			const followup = document.getElementById('feedback-followup');
			if (followup) followup.style.display = 'block';
		});
	});

	document.getElementById('feedback-submit')?.addEventListener('click', () => {
		const selected = document.querySelector('.feedback-btn.selected') as HTMLElement | null;
		const textEl = document.getElementById('feedback-text') as HTMLTextAreaElement | null;
		const value = selected?.getAttribute('data-value') ?? '';
		const text = textEl?.value ?? '';

		if (slug && value) {
			fetch(`/api/views/${slug}`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ feedback: value, feedbackText: text }),
			}).catch(() => {});
		}

		const container = document.getElementById('reader-feedback');
		const thanks = document.getElementById('feedback-thanks');
		if (container) {
			container.querySelectorAll('.feedback-options, .feedback-followup, .feedback-prompt').forEach((el) => {
				(el as HTMLElement).style.display = 'none';
			});
		}
		if (thanks) thanks.style.display = 'block';
	});
</script>

<style>
	main {
		width: 100%;
		max-width: 760px;
		margin: 0 auto;
		padding: 0 1.25rem;
	}

	/* ── Back link ── */
	.back-link {
		display: inline-block;
		margin-top: 1.5rem;
		font-size: 0.85rem;
		font-family: sans-serif;
		font-weight: 500;
		color: var(--color-text-muted);
		text-decoration: none;
	}

	.back-link:hover {
		color: var(--color-text-primary);
	}

	.hero-image {
		margin: 2rem 0;
	}

	.hero-image img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 8px;
	}

	.prose {
		padding: 1.5rem 0 3.5rem;
	}

	/* ── Essay header ── */
	.essay-header {
		margin-bottom: 1.5rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.5rem;
	}

	.tag {
		font-family: sans-serif;
		font-size: 0.8rem;
		font-weight: 500;
		color: var(--color-text-secondary);
		background: var(--color-bg-secondary);
		padding: 0.4rem 1rem;
		border-radius: 999px;
		text-decoration: none;
		border: 1px solid var(--color-border);
	}

	.tag:hover {
		color: var(--color-link);
		border-color: var(--color-link);
		background: var(--color-bg);
	}

	.essay-header h1 {
		font-size: clamp(1.5rem, 4.5vw, 2.25rem);
		font-weight: 800;
		line-height: 1.2;
		margin: 0;
		color: var(--color-text-primary);
		letter-spacing: -0.02em;
	}

	.date {
		display: block;
		font-size: 0.8rem;
		color: var(--color-text-secondary);
		font-family: sans-serif;
		margin-bottom: 0.5rem;
	}

	.dek {
		font-size: 1.1rem;
		line-height: 1.5;
		color: var(--color-text-secondary);
		margin: 0.5rem 0 0;
		font-style: italic;
	}

	.last-updated-on {
		font-style: italic;
	}

	/* ── Series navigation ── */
	.series-nav {
		background: var(--color-bg-secondary);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 1.25rem 1.5rem;
		margin-bottom: 2rem;
	}

	.series-nav-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 0.5rem;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.series-label {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--color-link);
		font-family: sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.series-position {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		font-family: sans-serif;
	}

	.series-description {
		font-size: 0.9rem;
		line-height: 1.5;
		color: var(--color-text-secondary);
		margin: 0 0 0.75rem;
	}

	.series-reading-order summary {
		font-size: 0.85rem;
		font-weight: 600;
		font-family: sans-serif;
		color: var(--color-link);
		cursor: pointer;
		user-select: none;
	}

	.series-reading-order summary:hover {
		color: var(--color-brand);
	}

	.series-reading-order ol {
		margin: 0.75rem 0 0;
		padding-left: 1.5rem;
	}

	.series-reading-order li {
		font-size: 0.85rem;
		line-height: 1.6;
		color: var(--color-text-secondary);
		font-family: sans-serif;
		margin-bottom: 0.25rem;
	}

	.series-reading-order li.current {
		font-weight: 700;
		color: var(--color-text-primary);
	}

	.series-reading-order li a {
		color: var(--color-link);
		text-decoration: none;
	}

	.series-reading-order li a:hover {
		text-decoration: underline;
	}

	/* ── Essay footer ── */
	.essay-footer {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--color-border);
	}

	.share-links {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 2rem;
	}

	.share-label {
		font-size: 0.8rem;
		font-weight: 600;
		font-family: sans-serif;
		color: var(--color-text-secondary);
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.social-buttons {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.share-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		color: var(--color-text-muted);
		background: none;
		border: 1px solid var(--color-border);
		border-radius: 6px;
		cursor: pointer;
		text-decoration: none;
	}

	.share-icon:hover {
		color: var(--color-link);
		border-color: var(--color-link);
	}

	/* ── Continue reading ── */
	.continue-reading {
		margin-bottom: 2rem;
	}

	.continue-reading h2 {
		font-size: 1.1rem;
		font-weight: 700;
		margin: 0 0 1rem;
		color: var(--color-text-primary);
		font-family: sans-serif;
	}

	.prev-next {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.prev-next-link {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 1rem 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
	}

	.prev-next-link:hover {
		border-color: var(--color-card-hover);
	}

	.prev-next-link.next {
		text-align: right;
	}

	.prev-next-label {
		font-size: 0.75rem;
		font-weight: 600;
		font-family: sans-serif;
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.prev-next-title {
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--color-text-primary);
		font-family: sans-serif;
		line-height: 1.3;
	}

	.series-entry {
		font-size: 0.9rem;
		color: var(--color-text-secondary);
		margin: 0;
	}

	.series-entry a {
		color: var(--color-link);
		text-decoration: none;
		font-weight: 600;
	}

	.series-entry a:hover {
		text-decoration: underline;
	}

	/* ── Email capture ── */
	.email-capture {
		padding: 1.25rem 1.5rem;
		background: var(--color-bg-secondary);
		border: 1px solid var(--color-border);
		border-radius: 8px;
	}

	.email-capture-label {
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--color-text-primary);
		font-family: sans-serif;
		margin: 0 0 0.75rem;
	}

	.email-capture-cta {
		display: inline-block;
		background: var(--color-brand);
		color: #fff;
		padding: 0.6rem 1.25rem;
		border-radius: 6px;
		text-decoration: none;
		font-size: 0.9rem;
		font-family: sans-serif;
		font-weight: 600;
	}

	.email-capture-cta:hover {
		background: var(--color-brand-hover);
	}

	/* ── Reader feedback ── */
	.reader-feedback {
		margin-top: 2rem;
		padding: 1.25rem 1.5rem;
		background: var(--color-bg-secondary);
		border: 1px solid var(--color-border);
		border-radius: 8px;
	}

	.feedback-prompt {
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--color-text-primary);
		font-family: sans-serif;
		margin: 0 0 0.75rem;
	}

	.feedback-options {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.feedback-btn {
		padding: 0.4rem 1rem;
		border: 1px solid var(--color-border);
		border-radius: 6px;
		background: var(--color-bg);
		color: var(--color-text-secondary);
		font-size: 0.85rem;
		font-family: sans-serif;
		cursor: pointer;
	}

	.feedback-btn:hover {
		border-color: var(--color-link);
		color: var(--color-link);
	}

	.feedback-btn.selected {
		border-color: var(--color-link);
		background: var(--color-link);
		color: #fff;
	}

	.feedback-followup {
		margin-top: 0.75rem;
	}

	.feedback-text-label {
		display: block;
		font-size: 0.85rem;
		color: var(--color-text-muted);
		margin-bottom: 0.4rem;
	}

	.feedback-textarea {
		width: 100%;
		padding: 0.5rem;
		border: 1px solid var(--color-border);
		border-radius: 6px;
		background: var(--color-bg);
		color: var(--color-text-primary);
		font-size: 0.85rem;
		font-family: sans-serif;
		resize: vertical;
	}

	.feedback-submit {
		margin-top: 0.5rem;
		padding: 0.4rem 1rem;
		background: var(--color-brand);
		color: #fff;
		border: none;
		border-radius: 6px;
		font-size: 0.85rem;
		font-family: sans-serif;
		font-weight: 600;
		cursor: pointer;
	}

	.feedback-submit:hover {
		background: var(--color-brand-hover);
	}

	.feedback-thanks {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		font-style: italic;
		margin: 0;
	}

	/* ── Prose content styling ── */
	.prose :global(h2) {
		font-size: clamp(1.2rem, 3vw, 1.5rem);
		font-weight: 700;
		margin: 2.5rem 0 1rem;
		color: var(--color-text-primary);
		line-height: 1.3;
	}

	.prose :global(h3) {
		font-size: clamp(1.05rem, 2.5vw, 1.25rem);
		font-weight: 700;
		margin: 2rem 0 0.75rem;
		color: var(--color-text-primary);
		line-height: 1.3;
	}

	.prose :global(p) {
