---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'] & { slug: string };

const { title, description, pubDate, updatedDate, heroImage, slug } = Astro.props;
const pageUrl = new URL(`/blog/${slug}/`, Astro.site).toString();
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<article data-slug={slug} data-url={pageUrl} data-title={title}>
				{heroImage && (
					<div class="hero-image">
						<img width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose">
					<header class="essay-header">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<span class="last-updated-on">
										&middot; Updated <FormattedDate date={updatedDate} />
									</span>
								)
							}
							<span class="view-count" id="view-count"></span>
						</div>
						<h1>{title}</h1>
						<div class="share-links">
							<button id="native-share" class="share-btn" style="display:none" aria-label="Share this essay">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
								<span>Share</span>
							</button>
							<div id="social-share" class="social-buttons">
								<a class="share-btn"
									href={`https://x.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(title)}`}
									target="_blank" rel="noopener noreferrer" aria-label="Share on X">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
									<span>X</span>
								</a>
								<a class="share-btn"
									href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`}
									target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
									<span>LinkedIn</span>
								</a>
								<button class="share-btn" id="copy-link" aria-label="Copy link">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
									<span>Copy link</span>
								</button>
							</div>
						</div>
						<hr />
					</header>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<script>
	const article = document.querySelector('article[data-slug]');
	const slug = article?.getAttribute('data-slug');
	const url = article?.getAttribute('data-url') ?? '';
	const title = article?.getAttribute('data-title') ?? '';

	// View count
	if (slug) {
		fetch(`/api/views/${slug}`, { method: 'POST' })
			.then(r => r.json())
			.then(data => {
				const el = document.getElementById('view-count');
				if (el && data.views > 0) {
					el.textContent = ` \u00b7 ${data.views} view${data.views === 1 ? '' : 's'}`;
				}
			})
			.catch(() => {});
	}

	// Share links
	const nativeBtn = document.getElementById('native-share');
	const socialDiv = document.getElementById('social-share');

	if (navigator.share) {
		if (nativeBtn) nativeBtn.style.display = 'inline-flex';
		if (socialDiv) socialDiv.style.display = 'none';

		nativeBtn?.addEventListener('click', () => {
			navigator.share({ title, url }).catch(() => {});
		});
	}

	// Copy link
	document.getElementById('copy-link')?.addEventListener('click', () => {
		navigator.clipboard.writeText(url).then(() => {
			const span = document.querySelector('#copy-link span');
			if (span) {
				span.textContent = 'Copied!';
				setTimeout(() => { span.textContent = 'Copy link'; }, 2000);
			}
		});
	});
</script>

<style>
	main {
		width: 100%;
		max-width: 760px;
		margin: 0 auto;
		padding: 0 1.25rem;
	}

	.hero-image {
		margin: 2rem 0;
	}

	.hero-image img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 8px;
	}

	.prose {
		padding: 2rem 0 3.5rem;
	}

	.essay-header {
		margin-bottom: 2rem;
	}

	.essay-header h1 {
		font-size: clamp(1.5rem, 4.5vw, 2.25rem);
		font-weight: 800;
		line-height: 1.2;
		margin: 0 0 0.75rem;
		color: #0f172a;
		letter-spacing: -0.02em;
	}

	.date {
		font-size: 0.85rem;
		color: #94a3b8;
		font-family: sans-serif;
		margin-bottom: 0.75rem;
	}

	.last-updated-on {
		font-style: italic;
	}

	/* Share links */
	.share-links {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}

	.social-buttons {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.share-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.35rem 0.7rem;
		font-size: 0.8rem;
		font-family: sans-serif;
		color: #64748b;
		background: none;
		border: 1px solid #e5e7eb;
		border-radius: 6px;
		cursor: pointer;
		text-decoration: none;
		line-height: 1;
	}

	.share-btn:hover {
		color: #2563eb;
		border-color: #2563eb;
	}

	.share-btn svg {
		flex-shrink: 0;
	}

	hr {
		border: none;
		border-top: 1px solid #e5e7eb;
		margin: 0;
	}

	/* Prose content styling */
	.prose :global(h2) {
		font-size: clamp(1.2rem, 3vw, 1.5rem);
		font-weight: 700;
		margin: 2.5rem 0 1rem;
		color: #0f172a;
		line-height: 1.3;
	}

	.prose :global(h3) {
		font-size: clamp(1.05rem, 2.5vw, 1.25rem);
		font-weight: 700;
		margin: 2rem 0 0.75rem;
		color: #1e293b;
		line-height: 1.3;
	}

	.prose :global(p) {
		font-size: 1rem;
		line-height: 1.75;
		color: #374151;
		margin: 0 0 1.25rem;
	}

	.prose :global(strong) {
		color: #1e293b;
	}

	.prose :global(em) {
		color: #475569;
	}

	.prose :global(a) {
		color: #2563eb;
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.prose :global(a:hover) {
		color: #1e3a8a;
	}

	.prose :global(blockquote) {
		border-left: 3px solid #2563eb;
		padding: 0 0 0 1.25rem;
		margin: 1.5rem 0;
		font-size: 1rem;
	}

	.prose :global(blockquote p) {
		color: #475569;
	}

	.prose :global(code) {
		font-size: 0.9em;
		background: #f1f5f9;
		padding: 0.15em 0.35em;
		border-radius: 3px;
	}

	.prose :global(pre) {
		background: #1e293b;
		color: #e2e8f0;
		padding: 1.25rem;
		border-radius: 8px;
		overflow-x: auto;
		margin: 1.5rem 0;
	}

	.prose :global(pre code) {
		background: none;
		padding: 0;
		font-size: 0.9rem;
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin: 1rem 0 1.25rem;
		padding-left: 1.5rem;
	}

	.prose :global(li) {
		font-size: 1rem;
		line-height: 1.75;
		color: #374151;
		margin-bottom: 0.5rem;
	}

	@media (max-width: 480px) {
		main {
			padding: 0 1rem;
		}

		.prose {
			padding: 1.5rem 0 3rem;
			font-size: 16px;
		}
	}
</style>
