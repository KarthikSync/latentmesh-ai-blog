{
	"name": "latentmesh-ai-blog",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"kv_namespaces": [
		{
			"binding": "VIEW_COUNTS",
			"id": "ca950fa8105745dc965484647189e041"
		}
	],
	"routes": [
		{
			"pattern": "latentmesh.ai",
			"custom_domain": true
		}
	]
}